# Workspace artifacts produced by the build-and-release workflow.
# These must never be committed (a push to main re-triggers the build).
upstream/
dist/
release-notes.md
patch-apply.log

# Build output / local experiments
*.apk
*.apk.sha256

# macOS
.DS_Store

# Never commit a signing keystore (the release key is private; CI gets it from a secret)
*.jks
*.keystore
keystore/*.jks
keystore/*.keystore
